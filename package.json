{
  "name": "genba-mvp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:front": "vite",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "db:create": "wrangler d1 create genba-mvp",
    "db:migrate:local": "wrangler d1 migrations apply genba-mvp --local",
    "db:migrate:remote": "wrangler d1 migrations apply genba-mvp --remote"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
